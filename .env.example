# API Config
PORT=3000
WS_PORT=3001
NODE_ENV=development

# Database (Prisma)
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=photobooth
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/photobooth?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# Mercado Pago
MERCADO_PAGO_ACCESS_TOKEN=your_access_token_here
MERCADO_PAGO_PUBLIC_KEY=your_public_key_here
MERCADO_PAGO_WEBHOOK_SECRET=your_webhook_secret_here

# Security
BOOTH_AUTH_TOKEN=mudar_para_um_token_seguro_123
JWT_SECRET=secret_para_frontend_se_necessario

# Business Logic
PIX_EXPIRATION_MINUTES=2
